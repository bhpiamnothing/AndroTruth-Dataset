      "permission_details": {
        "android.permission.ACCESS_FINE_LOCATION": {
          "permission_type": "dangerous",
          "short_description": "access precise location (GPS and\n      network-based)",
          "full_description": "Allows the app to get your\n      precise location using the Global Positioning System (GPS) or network\n      location sources such as cell towers and Wi-Fi. These location services\n      must be turned on and available to your device for the app to use them.\n      Apps may use this to determine where you are, and may consume additional\n      battery power."
        },
        "android.permission.DISABLE_KEYGUARD": {
          "permission_type": "normal",
          "short_description": "disable your screen lock",
          "full_description": "Allows the app to disable the\n      keylock and any associated password security.  For example, the phone\n      disables the keylock when receiving an incoming phone call, then\n      re-enables the keylock when the call is finished."
        },
        "android.permission.INTERNET": {
          "permission_type": "normal",
          "short_description": "have full network access",
          "full_description": "Allows the app to create\n     network sockets and use custom network protocols. The browser and other\n     applications provide means to send data to the internet, so this\n     permission is not required to send data to the internet."
        },
        "android.permission.READ_EXTERNAL_STORAGE": {
          "permission_type": "dangerous",
          "short_description": "read the contents of your SD card",
          "full_description": "Allows the app to read the contents of your SD card."
        },
        "android.permission.ACCESS_WIFI_STATE": {
          "permission_type": "normal",
          "short_description": "view Wi-Fi connections",
          "full_description": "Allows the app to view information\n      about Wi-Fi networking, such as whether Wi-Fi is enabled and name of\n      connected Wi-Fi devices."
        },
        "android.permission.ACCESS_COARSE_LOCATION": {
          "permission_type": "dangerous",
          "short_description": "access approximate location\n      (network-based)",
          "full_description": "Allows the app to get your\n      approximate location. This location is derived by location services using\n      network location sources such as cell towers and Wi-Fi. These location\n      services must be turned on and available to your device for the app to\n      use them. Apps may use this to determine approximately where you\n      are."
        },
        "android.permission.WAKE_LOCK": {
          "permission_type": "normal",
          "short_description": "prevent phone from sleeping",
