        },
        "android.permission.READ_LOGS": {
          "permission_type": "signature|system|development",
          "short_description": "read sensitive log data",
          "full_description": "Allows the app to read from the\n        system's various log files.  This allows it to discover general\n        information about what you are doing with the phone, potentially\n        including personal or private information."
        },
        "android.permission.ACCESS_NETWORK_STATE": {
          "permission_type": "normal",
