        "android.permission.ACCESS_FINE_LOCATION": {
          "permission_type": "dangerous",
          "short_description": "precise location (GPS and\n      network-based)",
          "full_description": "Allows the app to get your\n      precise location using the Global Positioning System (GPS) or network\n      location sources such as cell towers and Wi-Fi. These location services\n      must be turned on and available to your device for the app to use them.\n      Apps may use this to determine where you are, and may consume additional\n      battery power."
        },
        "android.permission.RECEIVE_BOOT_COMPLETED": {
          "permission_type": "normal",
          "short_description": "run at startup",
          "full_description": "Allows the app to\n        have itself started as soon as the system has finished booting.\n        This can make it take longer to start the phone and allow the\n        app to slow down the overall phone by always running."
        },
        "com.android.launcher.permission.UNINSTALL_SHORTCUT": {
          "permission_type": "dangerous",
          "short_description": "uninstall shortcuts",
          "full_description": "Allows the application to remove\n        Homescreen shortcuts without user intervention."
        },
        "android.permission.READ_PHONE_STATE": {
          "permission_type": "dangerous",
          "short_description": "read phone status and identity",
          "full_description": "Allows the app to access the phone\n      features of the device.  This permission allows the app to determine the\n      phone number and device IDs, whether a call is active, and the remote number\n      connected by a call."
        },
        "com.android.launcher.permission.INSTALL_SHORTCUT": {
          "permission_type": "dangerous",
          "short_description": "install shortcuts",
          "full_description": "Allows an application to add\n        Homescreen shortcuts without user intervention."
        },
        "android.permission.CAMERA": {
          "permission_type": "dangerous",
          "short_description": "take pictures and videos",
          "full_description": "Allows the app to take pictures and videos\n      with the camera.  This permission allows the app to use the camera at any\n      time without your confirmation."
        },
        "android.permission.ACCESS_COARSE_LOCATION": {
          "permission_type": "dangerous",
          "short_description": "approximate location\n      (network-based)",
          "full_description": "Allows the app to get your\n      approximate location. This location is derived by location services using\n      network location sources such as cell towers and Wi-Fi. These location\n      services must be turned on and available to your device for the app to\n      use them. Apps may use this to determine approximately where you\n      are."
        },
        "android.permission.WAKE_LOCK": {
          "permission_type": "normal",
          "short_description": "prevent phone from sleeping",
          "full_description": "Allows the app to prevent the phone from going to sleep."
        },
        "android.permission.ACCESS_WIFI_STATE": {
          "permission_type": "normal",
          "short_description": "view Wi-Fi connections",
          "full_description": "Allows the app to view information\n      about Wi-Fi networking, such as whether Wi-Fi is enabled and name of\n      connected Wi-Fi devices."
        },
