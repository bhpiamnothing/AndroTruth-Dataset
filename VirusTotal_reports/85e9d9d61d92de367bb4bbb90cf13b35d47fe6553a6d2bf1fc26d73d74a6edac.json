        "android.permission.ACCESS_FINE_LOCATION": {
          "permission_type": "dangerous",
          "short_description": "precise location (GPS and\n      network-based)",
          "full_description": "Allows the app to get your\n      precise location using the Global Positioning System (GPS) or network\n      location sources such as cell towers and Wi-Fi. These location services\n      must be turned on and available to your device for the app to use them.\n      Apps may use this to determine where you are, and may consume additional\n      battery power."
        },
        "android.permission.RECEIVE_BOOT_COMPLETED": {
          "permission_type": "normal",
          "short_description": "run at startup",
          "full_description": "Allows the app to\n        have itself started as soon as the system has finished booting.\n        This can make it take longer to start the phone and allow the\n        app to slow down the overall phone by always running."
